POSTGRES_PASSWORD=
POSTGRES_USER=
POSTGRES_DB=

# Runtime environment
NODE_ENV=production

# API CORS. Development/test allow local origins; production must list both surfaces.
PUBLIC_FRONTEND_ORIGINS=https://app.example.com
BACKOFFICE_FRONTEND_ORIGINS=https://backoffice.example.com

# Backoffice container runtime configuration.
BACKOFFICE_API_URL=https://api.example.com/admin
BACKOFFICE_PRODUCTION=true
BACKOFFICE_ADMIN_TOKEN_STORAGE_KEY=proxi.backoffice.adminToken

# Backend telemetry.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
