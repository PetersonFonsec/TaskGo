{
  "uid": "proxi-backoffice-observability",
  "title": "Proxi Backoffice Observability",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Admin Login Failures",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(admin_login_attempts_total{result=\"failure\"}[5m]))",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Audit Write Failures",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(admin_audit_write_failures_total[5m]))",
          "legendFormat": "audit failures"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Admin API 5xx",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum by (route) (increase(admin_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider and Audit List p95",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "admin_list_endpoint_duration_ms_p95",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Database Query Duration p95",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "admin_database_query_duration_ms_p95",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
