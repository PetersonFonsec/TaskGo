{
  "name": "taskgo-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/backoffice",
    "apps/frontend",
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "backend": "nx serve backend",
    "backoffice": "nx serve backoffice",
    "backoffice:build": "nx build backoffice",
    "backoffice:test": "nx test backoffice",
    "backoffice:e2e": "nx e2e backoffice",
    "frontend": "nx serve frontend",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@nx/js": "^22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "~4.1.0",
    "nx": "^21.0.0",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {}
}
