// schema.prisma — Proxi (NestJS + Prisma ORM)
// Versão sem PostGIS (usa lat/lng e Json para área)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserType {
  CLIENTE
  PRESTADOR
  ADMIN
}

enum ServiceStatus {
  ATIVO
  INATIVO
}

enum OrderStatus {
  AGUARDANDO_APROVACAO
  REJEITADO
  AGUARDANDO_PAGAMENTO
  AGENDADO
  EM_DESLOCAMENTO
  EM_ANDAMENTO
  AGUARDANDO_CONFIRMACAO_CLIENTE
  CONCLUIDO
  CANCELADO
  DISPUTA
}

enum PaymentMethod {
  PIX
  CARTAO
  OUTRO
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  RELEASED
  REFUNDED
  FAILED
  CANCELED
}

enum ServiceAreaMode {
  RADIUS
  POLYGON
}

enum OrderEventType {
  REQUESTED
  ACCEPTED
  PAYMENT_AUTHORIZED
  PROVIDER_ON_THE_WAY
  SERVICE_STARTED
  PRICE_UPDATED
  SERVICE_FINISHED
  CLIENT_CONFIRMED
  PAYMENT_CAPTURED
  PAYMENT_RELEASED
  CANCELED
  CLIENT_REVIEWED
}

enum OrderPhotoType {
  BEFORE
  AFTER
  RECEIPT
  DAMAGE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

// ---------- Models ----------

model User {
  id                 BigInt    @id @default(autoincrement())
  name               String    @map("nome")
  email              String    @unique
  passwordHash       String    @map("senha_hash")
  phone              String?   @map("telefone")
  emailVerified      Boolean   @default(false) @map("email_verified")
  phoneVerified      Boolean   @default(false) @map("phone_verified")
  pendingEmail       String?   @map("pending_email")
  pendingPhone       String?   @map("pending_phone")
  type               UserType  @map("tipo")
  photoUrl           String?   @map("foto_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  cpf                String    @unique @map("cpf")

  // Relations
  provider  Provider?
  addresses Address[]
  orders    Order[]          @relation("UserOrders")
  reviews   Avaliacao[]      @relation("UserReviews")
  favorites ClientFavorite[]

  @@map("usuarios")
}

model Provider {
  id             BigInt   @id
  // 1:1 with User (same PK)
  user           User     @relation(fields: [id], references: [id], onDelete: Cascade)
  bio            String?
  ratingAvg      Decimal? @default(0) @map("nota_media")
  ratingCount    Int      @default(0) @map("qtd_avaliacoes")
  verified       Boolean  @default(false) @map("verificado")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  acceptPix      Boolean  @default(false) @map("aceitaPix")
  acceptsCard    Boolean  @default(false) @map("aceitaCartao")
  emergencyCare  Boolean  @default(false) @map("aceitaEmergencia")
  isAvailable24h Boolean  @default(false) @map("disponivel24h")

  pagarmeRecipientId String? @unique @map("pagarme_recipient_id")

  services     Service[]
  serviceAreas ProviderServiceArea[]
  locations    ProviderLocation[]
  reviews      Avaliacao[]
  favorites    ClientFavorite[]

  @@map("prestadores")
}

model ClientFavorite {
  id         BigInt   @id @default(autoincrement())
  clientId   BigInt   @map("cliente_id")
  providerId BigInt   @map("prestador_id")
  createdAt  DateTime @default(now()) @map("created_at")

  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([clientId, providerId])
  @@index([clientId])
  @@index([clientId, providerId])
  @@map("client_favorites")
}

model Service {
  id           BigInt        @id @default(autoincrement())
  providerId   BigInt        @map("prestador_id")
  title        String        @map("titulo")
  description  String?       @map("descricao")
  category     String        @map("categoria")
  basePrice    Decimal       @map("preco_base")
  availability Json?         @map("disponibilidade")
  status       ServiceStatus @default(ATIVO)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  platformFeePct Decimal? @map("platform_fee_pct")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([providerId])
  @@index([category])
  @@map("servicos")
}

model Order {
  id                    BigInt      @id @default(autoincrement())
  clientId              BigInt      @map("cliente_id")
  serviceId             BigInt      @map("servico_id")
  status                OrderStatus
  finalPrice            Decimal?    @map("preco_final")
  requestedAt           DateTime    @default(now()) @map("solicitado_em")
  scheduledFor          DateTime?   @map("executar_em")
  estimatedPrice        Decimal?
  priceAdjusted         Boolean     @default(false) @map("preco_ajustado")
  priceAdjustmentReason String?     @map("motivo_ajuste_preco")
  providerFinishedAt    DateTime?   @map("provider_finished_at")
  clientConfirmedAt     DateTime?   @map("client_confirmed_at")

  // Relations
  client        User           @relation("UserOrders", fields: [clientId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  payment       Payment?
  review        Avaliacao?
  addressSnap   OrderAddress?
  orderTimeline OrderTimeline[]
  orderPhoto    OrderPhoto[]
  completion    OrderCompletion?

  @@index([clientId])
  @@index([serviceId])
  @@map("pedidos")
}

model OrderTimeline {
  id          BigInt         @id @default(autoincrement())
  orderId     BigInt         @map("pedido_id")
  event       OrderEventType
  description String?
  createdBy   UserType
  createdAt   DateTime

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("historico_pedido")
}

model OrderPhoto {
  id         BigInt         @id @default(autoincrement())
  orderId    BigInt         @map("pedido_id")
  uploadedBy UserType
  url        String
  type       OrderPhotoType
  createdAt  DateTime

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("evidencia_pedido_executado")
}

model OrderCompletion {
  id                    BigInt    @id @default(autoincrement())
  orderId               BigInt    @unique @map("order_id")
  completedByProviderAt DateTime? @map("completed_by_provider_at")
  confirmedByClientAt   DateTime? @map("confirmed_by_client_at")
  providerNotes         String?   @map("provider_notes")
  clientNotes           String?   @map("client_notes")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_completions")
}

model Payment {
  id      BigInt        @id @default(autoincrement())
  orderId BigInt        @unique @map("pedido_id")
  method  PaymentMethod @map("metodo")
  status  PaymentStatus @map("status")
  amount  Decimal       @map("valor")
  paidAt  DateTime?     @map("pago_em")

  provider         String    @default("PAGARME")
  providerOrderId  String?   @unique @map("provider_order_id")
  providerChargeId String?   @unique @map("provider_charge_id")
  pixQrCode        String?   @map("pix_qrcode")
  pixQrCodeBase64  String?   @map("pix_qrcode_base64")
  pixExpiresAt     DateTime? @map("pix_expires_at")

  // NEW: split amounts (em moeda, não centavos)
  platformAmount Decimal? @map("platform_amount")
  providerAmount Decimal? @map("provider_amount")
  feePct         Decimal? @map("fee_pct") // 0.12 = 12%

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

model Avaliacao {
  id         BigInt   @id @default(autoincrement())
  orderId    BigInt   @unique @map("pedido_id")
  clientId   BigInt   @map("cliente_id")
  providerId BigInt   @map("prestador_id")
  rating     Int      @map("nota")
  comment    String?  @map("comentario")
  reviewedAt DateTime @default(now()) @map("avaliado_em")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  client   User     @relation("UserReviews", fields: [clientId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@map("avaliacoes")
}

model Address {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt?  @map("user_id")
  label        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String?  @default("BR")
  cep          String?
  // Substitui geography(Point,4326)
  lat          Float?   @db.DoublePrecision
  lng          Float?   @db.DoublePrecision
  placeId      String?  @map("place_id")
  isDefault    Boolean  @default(false) @map("is_default")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cep])
  @@index([lat, lng])
  @@map("addresses")
}

model OrderAddress {
  id           BigInt   @id @default(autoincrement())
  orderId      BigInt   @unique @map("order_id")
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String?  @default("BR")
  cep          String?
  // Substitui geography(Point,4326)
  lat          Float?   @db.DoublePrecision
  lng          Float?   @db.DoublePrecision
  createdAt    DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([lat, lng])
  @@map("order_addresses")
}

model ProviderServiceArea {
  id         BigInt          @id @default(autoincrement())
  providerId BigInt          @map("provider_id")
  mode       ServiceAreaMode
  // Substitui center geography(Point,4326)
  centerLat  Float?          @db.DoublePrecision
  centerLng  Float?          @db.DoublePrecision
  radiusKm   Decimal?        @map("radius_km")
  // Substitui polygon geography(Polygon,4326) -> GeoJSON
  polygon    Json?
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([centerLat, centerLng])
  @@map("provider_service_areas")
}

model ProviderLocation {
  id         BigInt   @id @default(autoincrement())
  providerId BigInt   @map("provider_id")
  // Substitui geography(Point,4326)
  lat        Float    @db.DoublePrecision
  lng        Float    @db.DoublePrecision
  capturedAt DateTime @default(now()) @map("captured_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([capturedAt])
  @@index([lat, lng])
  @@map("provider_locations")
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  thumb       String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platformFeePct Decimal? @map("platform_fee_pct")

  subcategories Subcategory[]

  @@index([isActive])
  @@map("categories")
}

model Subcategory {
  id          BigInt   @id @default(autoincrement())
  categoryId  BigInt
  name        String
  slug        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug], name: "categoryId_slug")
  @@index([categoryId])
  @@index([isActive])
  @@map("subcategories")
}

model FeatureFlag {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("feature_flags")
}

model OrderDispute {
  id          BigInt        @id @default(autoincrement())
  orderId     BigInt
  openedBy    UserType
  reason      String
  description String
  status      DisputeStatus
  createdAt   DateTime      @default(now())
}
