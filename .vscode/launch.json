{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug E2E Nest (monorepo)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "test:e2e"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "internalConsoleOptions": "neverOpen",
      "autoAttachChildProcesses": true,
      "stopOnEntry": false
    }
  ]
}